---
import Header from '../layouts/Header.astro';

const cresenTechStack = [
    'Java',
    'Spring Boot',
    'Microservices',
    'Kafka',
    'Angular',
    'PostgreSQL',
    'Azure'
]
const cognizantTechStack = [
    'Unqork',
    'Java',
    'Maven',
    'Gradle',
    'Spring',
    'GWT',
    'MySQL'
]
---

<section id="Experience" class="has-header">
    <div class="container flow">
        <div class="flow">
            <h3>Jan, 2024 - Present</h3>
            <h2>eXp Realty</h2>
            <p class="secondary">
                Engineering Lead with 5+ years of experience leading an AI-powered
                voice platform. Lead a team of 6 engineers to manage voice concierge
                services within the Twilio ecosystem.
            </p>
            <p class="secondary">
                Architected a backend system from scratch using Node.js and Fastify,
                handling 4,500+ calls and 2,000+ messages daily. Built Kafka-based
                pub/sub pipelines and Redis session/caching layers.
            </p>
            <p class="secondary">
                Refactored the frontend by consolidating 15+ separate plugins into a
                single modular Twilio Flex plugin with authentication and
                authorization. Implemented real-time transcription, summarization,
                and supervisor dashboards; engineered an AI voice agent that
                eliminated a $10k/month vendor expense.
            </p>
            <p class="secondary">
                Reduced post-call documentation time from 10 minutes to 5 seconds,
                saving $25k/month. Optimized Twilio costs by 80% through automated
                spam filtering and cut AWS infrastructure costs by 90% by replacing
                legacy voice anomaly detection with an AI-driven podcast review
                solution.
            </p>
            <div class="techstack">
                {['Node.js','Fastify','Kafka','Redis','Twilio','React','Flutter','AWS'].map(i => <p>{i}</p>)}
            </div>
        </div>
        <div class="flow">
            <h3>Aug, 2022 - Jan, 2024</h3>
            <h2>Cresen Solutions</h2>
            <p class="secondary">
                Software Engineer working on a Spring Boot microservices application
                and Angular frontend for a medical-domain product.
            </p>
            <p class="secondary">
                Designed and implemented a secure two-factor authentication flow,
                optimized the UI for mobile devices, and led refactoring for an
                Angular 14 upgrade.
            </p>
            <p class="secondary">
                Contributed to intern mentorship and hiring by participating in
                technical interviews and improving overall code quality.
            </p>
            <div class="techstack">
                {cresenTechStack.map(i => <p>{i}</p>)}
            </div>
        </div>
        <div class="flow">
            <h3>Oct, 2020 - Aug, 2022</h3>
            <h2>Cognizant</h2>
            <p class="secondary">
                Junior Product Specialist and offshore lead for an insurance portal
                project. Delivered a new insurance portal for a Latin American bank,
                reducing policy issuance time by 40%.
            </p>
            <p class="secondary">
                Maintained a complex data grid system with 20+ logic-heavy
                calculation components, debugged Java applications, and supported
                product reliability.
            </p>
            <p class="secondary">
                Achieved certification as the first developer in the company to pass
                the Unqork platform developer exam.
            </p>
            <div class="techstack">
                {cognizantTechStack.map(i => <p>{i}</p>)}
            </div>
        </div>
    </div>
</section>

<style lang="scss">
    .techstack {
        display: flex;
        column-gap: var(--unit);
        flex-wrap: wrap;
        
        p {
            width: max-content;
            text-transform: uppercase;
        }
    }
</style>